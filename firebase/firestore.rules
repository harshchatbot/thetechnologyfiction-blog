rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if resource.data.status == "published";
      allow write: if request.auth != null && request.auth.token.email in ['founder@example.com'];
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in ['founder@example.com'];
    }

    match /tags/{tagId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in ['founder@example.com'];
    }

    match /media/{mediaId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in ['founder@example.com'];
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in ['founder@example.com'];
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
